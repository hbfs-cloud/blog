---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeCategory?: string;
}

const { title, description = 'Blog privé El Ouadi', activeCategory } = Astro.props;
const base = import.meta.env.BASE_URL;

const categories = [
  { id: 'family', label: 'Famille', icon: 'fa-users', color: 'var(--cat-family)' },
  { id: 'fatima', label: 'Fatima', icon: 'fa-heart', color: 'var(--cat-fatima)' },
  { id: 'yassine', label: 'Yassine', icon: 'fa-graduation-cap', color: 'var(--cat-yassine)' },
  { id: 'soufiane', label: 'Soufiane', icon: 'fa-flask', color: 'var(--cat-soufiane)' },
  { id: 'youssouf', label: 'Youssouf', icon: 'fa-futbol', color: 'var(--cat-youssouf)' },
  { id: 'salma', label: 'Salma', icon: 'fa-star', color: 'var(--cat-salma)' },
  { id: 'veille', label: 'Veille', icon: 'fa-radar', color: 'var(--cat-veille)' },
  { id: 'reputation', label: 'Réputation', icon: 'fa-shield-halved', color: 'var(--cat-reputation)' },
  { id: 'business', label: 'Business', icon: 'fa-briefcase', color: 'var(--cat-business)' },
  { id: 'retrospectives', label: 'Rétros', icon: 'fa-rotate-left', color: 'var(--cat-retrospectives)' },
  { id: 'review-strategy', label: 'Portfolios', icon: 'fa-chart-line', color: 'var(--cat-review-strategy)' },
];

const familySection = categories.filter(c => ['family','fatima','yassine','soufiane','youssouf','salma'].includes(c.id));
const workSection = categories.filter(c => ['veille','reputation','business','retrospectives','review-strategy'].includes(c.id));
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Market Watch</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
</head>
<body>
  <div class="app-layout">
    <!-- Mobile overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-brand">
        <h1><img src="/logo.svg" alt="MW" width="28" height="28" style="vertical-align:middle;margin-right:8px;">Market Watch</h1>
        <p>Institutional Intelligence</p>
      </div>

      <nav class="sidebar-section">
        <div class="sidebar-section-title">Navigation</div>
        <a href={`${base}`} class={`sidebar-link ${!activeCategory ? 'active' : ''}`}>
          <i class="fa-solid fa-house" style="width:16px;text-align:center;"></i> Accueil
        </a>
        <a href={`${base}calendar/`} class="sidebar-link">
          <i class="fa-solid fa-calendar-days" style="width:16px;text-align:center;"></i> Calendrier
        </a>
      </nav>

      <nav class="sidebar-section">
        <div class="sidebar-section-title">Famille</div>
        {familySection.map(cat => (
          <a href={`${base}${cat.id}/`} class={`sidebar-link ${activeCategory === cat.id ? 'active' : ''}`}>
            <span class="cat-dot" style={`background:${cat.color}`}></span>
            {cat.label}
          </a>
        ))}
      </nav>

      <nav class="sidebar-section">
        <div class="sidebar-section-title">Travail</div>
        {workSection.map(cat => (
          <a href={`${base}${cat.id}/`} class={`sidebar-link ${activeCategory === cat.id ? 'active' : ''}`}>
            <span class="cat-dot" style={`background:${cat.color}`}></span>
            {cat.label}
          </a>
        ))}
      </nav>
    </aside>

    <main class="main-content">
      <header class="top-bar">
        <button class="mobile-toggle" id="menuToggle" aria-label="Menu">
          <i class="fa-solid fa-bars" id="menuIcon"></i>
        </button>
        <span class="top-bar-title">{title}</span>
        <button class="search-btn" id="searchBtn">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span class="search-btn-text">Rechercher</span>
          <kbd>⌘K</kbd>
        </button>
      </header>

      <div class="content-area">
        <slot />
      </div>

      <footer class="footer">
        <p>&copy; {new Date().getFullYear()} El Ouadi — Journal priv&eacute;</p>
      </footer>
    </main>
  </div>

  <!-- Search modal -->
  <div id="searchModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);">
    <div style="max-width:600px;margin:10vh auto;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-hover);overflow:hidden;">
      <div style="display:flex;align-items:center;padding:0.75rem 1rem;border-bottom:1px solid var(--border);gap:0.5rem;">
        <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted);"></i>
        <input id="searchInput" type="text" placeholder="Rechercher un article..." style="flex:1;border:none;background:transparent;color:var(--text-primary);font-size:0.95rem;outline:none;" />
        <kbd style="font-size:0.65rem;padding:0.15rem 0.4rem;border:1px solid var(--border);border-radius:4px;color:var(--text-muted);">ESC</kbd>
      </div>
      <div id="searchResults" style="max-height:60vh;overflow-y:auto;padding:0.5rem;"></div>
    </div>
  </div>

  <!-- Scroll to top FAB -->
  <button class="fab" id="scrollTopBtn" style="display:none;" aria-label="Retour en haut">
    <i class="fa-solid fa-arrow-up"></i>
  </button>

  <script is:inline>
    // Mobile sidebar toggle with overlay
    const toggle = document.getElementById('menuToggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    const menuIcon = document.getElementById('menuIcon');

    function openSidebar() {
      sidebar.classList.add('open');
      overlay.classList.add('active');
      menuIcon.className = 'fa-solid fa-xmark';
    }
    function closeSidebar() {
      sidebar.classList.remove('open');
      overlay.classList.remove('active');
      menuIcon.className = 'fa-solid fa-bars';
    }

    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        if (sidebar.classList.contains('open')) closeSidebar();
        else openSidebar();
      });
      if (overlay) overlay.addEventListener('click', closeSidebar);
    }

    // Search
    var searchModal = document.getElementById('searchModal');
    var searchInput = document.getElementById('searchInput');
    var searchResults = document.getElementById('searchResults');
    var searchIndex = null;
    var searchBtn = document.getElementById('searchBtn');

    var categoryLabels = {
      family: 'Famille', fatima: 'Fatima', yassine: 'Yassine', soufiane: 'Soufiane',
      youssouf: 'Youssouf', salma: 'Salma', veille: 'Veille', reputation: 'Réputation',
      business: 'Business', retrospectives: 'Rétros', 'review-strategy': 'Portfolios'
    };
    var categoryColors = {
      family: '#8b5cf6', fatima: '#ec4899', yassine: '#3b82f6', soufiane: '#22c55e',
      youssouf: '#f59e0b', salma: '#f472b6', veille: '#14b8a6', reputation: '#f97316',
      business: '#0ea5e9', retrospectives: '#6366f1', 'review-strategy': '#eab308'
    };

    function openSearch() {
      searchModal.style.display = 'block';
      searchInput.value = '';
      searchInput.focus();
      searchResults.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:2rem;font-size:0.85rem;">Tapez pour rechercher...</p>';
      if (!searchIndex) {
        fetch('/search.json').then(function(r) { return r.json(); }).then(function(data) { searchIndex = data; });
      }
    }
    function closeSearch() { searchModal.style.display = 'none'; }

    if (searchBtn) searchBtn.addEventListener('click', openSearch);
    if (searchModal) searchModal.addEventListener('click', function(e) { if (e.target === searchModal) closeSearch(); });

    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
      if (e.key === 'Escape' && searchModal.style.display === 'block') closeSearch();
    });

    if (searchInput) searchInput.addEventListener('input', function() {
      if (!searchIndex) return;
      var q = searchInput.value.toLowerCase().trim();
      if (!q) { searchResults.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:2rem;font-size:0.85rem;">Tapez pour rechercher...</p>'; return; }
      var results = searchIndex.filter(function(p) {
        return p.title.toLowerCase().includes(q) || p.description.toLowerCase().includes(q) || (p.tags || []).some(function(t) { return t.toLowerCase().includes(q); }) || p.category.toLowerCase().includes(q);
      }).slice(0, 10);
      if (!results.length) { searchResults.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:2rem;font-size:0.85rem;">Aucun résultat</p>'; return; }
      searchResults.innerHTML = results.map(function(p) {
        var color = categoryColors[p.category] || '#3b82f6';
        var label = categoryLabels[p.category] || p.category;
        return '<a href="' + p.href + '" style="display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.75rem;border-radius:8px;text-decoration:none;color:inherit;transition:background 0.15s;" onmouseover="this.style.background=\'var(--bg-surface)\'" onmouseout="this.style.background=\'transparent\'">' +
          '<span style="width:8px;height:8px;border-radius:50%;background:' + color + ';flex-shrink:0;"></span>' +
          '<div style="flex:1;min-width:0;">' +
            '<div style="font-weight:600;font-size:0.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + p.title + '</div>' +
            '<div style="font-size:0.7rem;color:var(--text-muted);">' + label + (p.description ? ' — ' + p.description.substring(0, 60) : '') + '</div>' +
          '</div></a>';
      }).join('');
    });

    // Scroll to top FAB
    const fab = document.getElementById('scrollTopBtn');
    if (fab) {
      window.addEventListener('scroll', () => {
        fab.style.display = window.scrollY > 400 ? 'flex' : 'none';
      });
      fab.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  </script>
</body>
</html>
