---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const ALL_COLLECTIONS = ['family','fatima','yassine','soufiane','youssouf','salma','veille','reputation','business','retrospectives','review-strategy'] as const;

export async function getStaticPaths() {
  const collections = ['family','fatima','yassine','soufiane','youssouf','salma','veille','reputation','business','retrospectives','review-strategy'] as const;
  const allTags = new Set<string>();
  for (const name of collections) {
    try {
      const posts = await getCollection(name, ({ data }: any) => !data.draft);
      for (const post of posts) {
        (post.data as any).tags?.forEach((t: string) => allTags.add(t));
      }
    } catch (e) {}
  }
  return [...allTags].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

let matchingPosts: any[] = [];
for (const name of ALL_COLLECTIONS) {
  try {
    const posts = await getCollection(name, ({ data }: any) => !data.draft && data.tags?.includes(tag));
    matchingPosts.push(...posts.map((p: any) => ({ ...p, _collection: name })));
  } catch (e) {}
}

matchingPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title={`Tag: ${tag}`}>
  <div class="category-header">
    <h1><i class="fa-solid fa-tag"></i> {tag}</h1>
    <p>{matchingPosts.length} article{matchingPosts.length !== 1 ? 's' : ''}</p>
  </div>

  {matchingPosts.length > 0 ? (
    <div class="post-grid">
      {matchingPosts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          category={post._collection}
          tags={post.data.tags}
          image={post.data.image}
          href={`${base}${post._collection}/${post.id}/`}
        />
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <i class="fa-solid fa-tag"></i>
      <h3>Aucun article avec ce tag</h3>
    </div>
  )}
</BaseLayout>
