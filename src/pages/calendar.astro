---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const collectionNames = ['family','fatima','yassine','soufiane','youssouf','salma','veille','reputation','business','retrospectives','review-strategy'];

let allPosts: any[] = [];
for (const name of collectionNames) {
  try {
    const posts = await getCollection(name as any, ({ data }: any) => !data.draft);
    allPosts.push(...posts.map((p: any) => ({ ...p, _collection: name })));
  } catch (e) {}
}

const categoryColors: Record<string, string> = {
  family: '#8b5cf6', fatima: '#ec4899', yassine: '#3b82f6', soufiane: '#22c55e',
  youssouf: '#f59e0b', salma: '#f472b6', veille: '#14b8a6', reputation: '#f97316',
  business: '#0ea5e9', retrospectives: '#6366f1', 'review-strategy': '#eab308',
};

const categoryLabels: Record<string, string> = {
  family: 'Famille', fatima: 'Fatima', yassine: 'Yassine', soufiane: 'Soufiane',
  youssouf: 'Youssouf', salma: 'Salma', veille: 'Veille', reputation: 'Réputation',
  business: 'Business', retrospectives: 'Rétros', 'review-strategy': 'Portfolios',
};

// Build calendar data
const calendarData: Record<string, any[]> = {};
for (const post of allPosts) {
  const key = new Date(post.data.date).toISOString().slice(0, 10);
  if (!calendarData[key]) calendarData[key] = [];
  calendarData[key].push({
    title: post.data.title,
    category: post._collection,
    color: categoryColors[post._collection] || '#3b82f6',
    label: categoryLabels[post._collection] || post._collection,
    href: `${base}${post._collection}/${post.id}/`,
  });
}

// Active categories for legend
const activeCats = [...new Set(allPosts.map(p => p._collection))];
---
<BaseLayout title="Calendrier">
  <div class="category-header animate-in">
    <h1><i class="fa-solid fa-calendar-days"></i> Calendrier</h1>
    <p>Vue globale de toutes les publications</p>
  </div>

  <div id="calendar-app" class="animate-in delay-1" data-posts={JSON.stringify(calendarData)} data-base={base}>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
      <button id="prevMonth" class="search-btn"><i class="fa-solid fa-chevron-left"></i></button>
      <h2 id="monthTitle" style="font-size:1.15rem;font-weight:800;letter-spacing:-0.01em;"></h2>
      <button id="nextMonth" class="search-btn"><i class="fa-solid fa-chevron-right"></i></button>
    </div>
    <div class="calendar-grid" id="calGrid"></div>

    <!-- Category legend -->
    <div class="cal-legend">
      {activeCats.map(catId => (
        <div class="cal-legend-item">
          <span class="cal-dot" style={`background:${categoryColors[catId]};box-shadow:0 0 6px ${categoryColors[catId]};`}></span>
          {categoryLabels[catId]}
        </div>
      ))}
    </div>

    <!-- Day detail popup -->
    <div id="dayDetail" class="cal-day-detail" style="display:none;"></div>
  </div>

  <script is:inline>
    (function() {
      const app = document.getElementById('calendar-app');
      const posts = JSON.parse(app.dataset.posts);
      const base = app.dataset.base;
      let current = new Date();

      const days = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
      const months = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

      function render() {
        const year = current.getFullYear();
        const month = current.getMonth();
        document.getElementById('monthTitle').textContent = months[month] + ' ' + year;

        const first = new Date(year, month, 1);
        const last = new Date(year, month + 1, 0);
        let startDay = first.getDay() - 1;
        if (startDay < 0) startDay = 6;

        const grid = document.getElementById('calGrid');
        grid.innerHTML = days.map(d => '<div class="cal-header">' + d + '</div>').join('');

        const today = new Date().toISOString().slice(0, 10);

        // Previous month fill
        for (let i = 0; i < startDay; i++) {
          const d = new Date(year, month, -startDay + i + 1);
          grid.innerHTML += '<div class="cal-day other-month">' + d.getDate() + '</div>';
        }

        // Current month
        for (let d = 1; d <= last.getDate(); d++) {
          const key = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
          const dayPosts = posts[key] || [];
          const isToday = key === today;
          const cls = ['cal-day', isToday ? 'today' : '', dayPosts.length ? 'has-posts' : ''].filter(Boolean).join(' ');
          let dots = dayPosts.slice(0, 5).map(p => '<span class="cal-dot" style="background:' + p.color + ';box-shadow:0 0 4px ' + p.color + ';"></span>').join('');
          grid.innerHTML += '<div class="' + cls + '" data-date="' + key + '">' + d + (dots ? '<div class="cal-dots">' + dots + '</div>' : '') + '</div>';
        }

        // Bind click events
        grid.querySelectorAll('.has-posts').forEach(el => {
          el.addEventListener('click', () => showDay(el.dataset.date));
        });
      }

      function showDay(key) {
        const detail = document.getElementById('dayDetail');
        const dayPosts = posts[key] || [];
        if (!dayPosts.length) { detail.style.display = 'none'; return; }

        const dateObj = new Date(key + 'T00:00:00');
        const dateStr = dateObj.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

        detail.style.display = 'block';
        detail.innerHTML =
          '<h3><i class="fa-regular fa-calendar-check" style="margin-right:0.4rem;color:var(--accent);"></i> ' + dateStr + '</h3>' +
          dayPosts.map(p =>
            '<a href="' + p.href + '">' +
              '<span class="cat-dot" style="background:' + p.color + ';width:8px;height:8px;border-radius:50%;flex-shrink:0;box-shadow:0 0 6px ' + p.color + ';"></span>' +
              '<span style="flex:1;">' + p.title + '</span>' +
              '<span style="font-size:0.68rem;color:var(--text-muted);font-weight:500;">' + p.label + '</span>' +
            '</a>'
          ).join('');

        detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      document.getElementById('prevMonth').addEventListener('click', () => { current.setMonth(current.getMonth() - 1); render(); });
      document.getElementById('nextMonth').addEventListener('click', () => { current.setMonth(current.getMonth() + 1); render(); });
      render();
    })();
  </script>
</BaseLayout>
